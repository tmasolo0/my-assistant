# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# === LLM Provider ===
# Options: openrouter, anthropic, openai, ollama
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# Direct API keys (optional, for fallback)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama (only with --profile ollama)
OLLAMA_MODEL=llama3.1

# === Bot Identity ===
BOT_NAME=MyAssistant
BOT_LANGUAGE=ru

# === Infrastructure ===
POSTGRES_PASSWORD=changeme
POSTGRES_DB=assistant

# === Optional services ===
# Enable with: docker compose --profile <name> up -d
# Profiles: email, discord, whatsapp, slack, n8n, webui, ollama

# Email (profile: email)
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=

# Discord (profile: discord)
DISCORD_BOT_TOKEN=

# n8n (profile: n8n)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
