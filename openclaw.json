{
  // OpenClaw configuration
  // Docs: https://docs.openclaw.ai/gateway/configuration

  // Environment variables (secrets come from .env)
  env: {
    OPENROUTER_API_KEY: "${OPENROUTER_API_KEY}",
  },

  // Bot identity
  identity: {
    name: "${BOT_NAME}",
    theme: "helpful personal assistant",
  },

  // Agent & model settings
  agents: {
    defaults: {
      workspace: "./workspace",
      model: {
        primary: "openrouter/${OPENROUTER_MODEL}",
      },
      models: {
        "openrouter/anthropic/claude-sonnet-4-6": { alias: "Sonnet" },
        "openrouter/anthropic/claude-opus-4-6": { alias: "Opus" },
        "openrouter/openai/gpt-4.1": { alias: "GPT" },
        "openrouter/google/gemini-2.5-pro": { alias: "Gemini" },
      },
    },
  },

  // Telegram channel
  channels: {
    telegram: {
      enabled: true,
      botToken: "${TELEGRAM_BOT_TOKEN}",
      dmPolicy: "allowlist",
      allowFrom: ["${TELEGRAM_ALLOWED_CHAT_IDS}"],
    },
  },
}
